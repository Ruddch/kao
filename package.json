{
  "name": "kao",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/copy-404.mjs",
    "build:pages": "tsc -b && vite build --base /kao/ && node scripts/copy-404.mjs",
    "preview": "vite preview",
    "preview:pages": "vite preview --base /kao/",
    "lint": "eslint .",
    "sync-glyphs": "cp \"frontend 3/editor_glyph_pack.json\" public/glyphs/ && cp \"frontend 3/editor_lookup.json\" public/glyphs/ && cp \"frontend 3/editor_role_categories.json\" public/glyphs/ && node scripts/generate-glyph-fonts.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "@tanstack/react-query": "^5.101.0",
    "connectkit": "^1.9.2",
    "framer-motion": "^12.40.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.6.0",
    "rollup-plugin-node-polyfills": "^0.2.1",
    "viem": "^2.52.2",
    "wagmi": "^3.6.16"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.2.0"
  }
}
